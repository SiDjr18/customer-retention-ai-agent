# ── Application ─────────────────────────────────────────────────────────────��─
APP_NAME="Customer Retention AI Agent"
APP_VERSION="0.1.0"
DEBUG=false

# ── Server ────────────────────────────────��────────────────────────────��──────
HOST=0.0.0.0
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database (optional — default: SQLite) ────────────────────────────────────
DATABASE_URL=sqlite:///./retention.db
# DATABASE_URL=postgresql://user:password@localhost:5432/retention_db

# ── LLM / Agent (optional — agent works without this) ────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
AGENT_MAX_TOKENS=1024

# ── Data ──────────────────────────────────────────────────────────────────────
DATA_DIR=data
DATASET_FILENAME=01_Customer_Retention.csv

# ── Reports ────────────────────────────────────────────────────────────────���──
REPORTS_DIR=reports
